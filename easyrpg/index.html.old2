<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EasyRPG Player (Web Localizer)</title>
  
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

  <style>
    :root {
      --color-gray: hsl(0, 0%, 55%);
      --controls-size: 10vh;
    }

    @media (orientation: landscape) {
      :root {
        --controls-size: 20vh;
      }
    }

    html {
      touch-action: none;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      margin: 0;
      color: white;
      background: black;
    }

    /* 起動時のダイアログ用CSS */
    #startup-dialog {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.9);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 100;
    }

    .dialog-box {
      background: #222;
      padding: 2rem;
      border-radius: 8px;
      text-align: center;
      border: 1px solid var(--color-gray);
      max-width: 80%;
    }

    .dialog-box h2 {
      margin-top: 0;
      color: #fff;
    }

    .dialog-box p {
      color: #ccc;
      font-size: 0.95rem;
      line-height: 1.5;
    }

    #game-file-input {
      margin: 1.5rem 0;
      font-size: 1rem;
      color: white;
    }

    .unselectable {
      -webkit-touch-callout: none;
      -webkit-user-select: none;
      user-select: none;
    }

    #status {
      font-size: 1.2rem;
      color: #fff;
      text-shadow: 1px 1px 2px black;
      text-align: center;
      margin-top: 20px;
      position: absolute;
      width: 100%;
      z-index: 5;
    }

    #controls {
      position: relative;
      text-align: right;
      z-index: 10;
    }

    #controls button {
      -webkit-appearance: button;
      display: inline-flex;
      background: transparent;
      border: 0;
      color: white;
      font-family: inherit;
      font-size: 1em;
      line-height: inherit;
      cursor: pointer;
      padding: 0.5rem;
    }

    #controls svg {
      pointer-events: none;
    }

    #canvas {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 100%;
      height: 100%;
      border: 0;
      image-rendering: pixelated;
      image-rendering: crisp-edges;
      transform: translate(-50%, -50%);
    }

    img#canvas {
      object-fit: contain;
    }

    #dpad, #apad {
      position: fixed;
      bottom: 1rem;
    }
    #dpad { left: 1rem; }
    #apad { right: 1rem; }

    #dpad svg {
      width: calc(2 * var(--controls-size));
      height: calc(2 * var(--controls-size));
      fill: var(--color-gray);
    }
    #dpad svg rect { opacity: 0.4; }

    #apad > * {
      width: var(--controls-size);
      height: var(--controls-size);
      background-color: var(--color-gray);
      border-radius: 50%;
    }
    #apad > :last-child {
      position: relative;
      right: var(--controls-size);
    }
    #dpad path:not(.active), #apad > *:not(.active) {
      opacity: 0.4;
    }
  </style>
</head>
<body>

  <div id="startup-dialog" style="display: none;">
    <div class="dialog-box">
      <h2>ゲームを選択</h2>
      <p>
        遊ぶゲームのデータ（.zipファイル）を選択してください。<br>
        <small>※Shift-JIS・フォルダごと圧縮されたZIPにも対応しています。<br>※データはどこにもアップロードされません。</small>
      </p>
      <input type="file" id="game-file-input" accept=".zip">
    </div>
  </div>

<script>
// sessionStorageをチェックして、起動ダイアログの表示を制御
const hasGameData = sessionStorage.getItem('easyrpg_game_data');
const startupDialogElem = document.getElementById('startup-dialog');
if (!hasGameData) {
  startupDialogElem.style.display = 'flex';
}
</script>

  <div id="controls">
    <button id="controls-fullscreen" class="unselectable">
      <svg viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg" width="25" height="25"><path d="M13.5 13.5H10m3.5 0V10m0 3.5l-4-4m.5-8h3.5m0 0V5m0-3.5l-4 4M5 1.5H1.5m0 0V5m0-3.5l4 4m-4 4.5v3.5m0 0H5m-3.5 0l4-4" stroke="currentColor"></path></svg>
    </button>
  </div>

  <div id="status"></div>

  <div id="viewport">
    <canvas id="canvas" tabindex="-1" class="unselectable"></canvas>

    <div id="dpad" class="unselectable">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 72 72">
        <path id="dpad-up" data-key="ArrowUp" d="M48,5.8C48,2.5,45.4,0,42,0H29.9C26.6,0,24,2.4,24,5.8V24h24V5.8z" />
        <path id="dpad-right" data-key="ArrowRight" d="M66.2,24H48v24h18.2c3.3,0,5.8-2.7,5.8-6V29.9C72,26.5,69.5,24,66.2,24z" />
        <path id="dpad-down" data-key="ArrowDown" d="M24,66.3c0,3.3,2.6,5.7,5.9,5.7H42c3.3,0,6-2.4,6-5.7V48H24V66.3z" />
        <path id="dpad-left" data-key="ArrowLeft" d="M5.7,24C2.4,24,0,26.5,0,29.9V42c0,3.3,2.3,6,5.7,6H24V24H5.7z" />
        <rect id="dpad-center" x="24" y="24" width="24" height="24" />
      </svg>
    </div>

    <div id="apad" class="unselectable">
      <div id="apad-escape" data-key="Escape"></div>
      <div id="apad-enter" data-key="Enter"></div>
    </div>
  </div>

<script>
// ==========================================
// window.Moduleの定義（index.jsより前に実行される必要がある）
// ==========================================

const hasTouchscreen = window.matchMedia('(hover: none), (pointer: coarse)').matches;
const preventNativeKeys = ['ArrowUp', 'ArrowDown', 'ArrowRight', 'ArrowLeft', ' ', 'F12'];
const keys = new Map();
const keysDown = new Map();
const canvas = document.getElementById('canvas');
let easyrpgPlayer;
let lastTouchedId;

// ページロード時にsessionStorageからゲームデータを復元
const gameDataJson = sessionStorage.getItem('easyrpg_game_data');

if (gameDataJson) {
  console.log("Game data found in sessionStorage, setting up preRun");
  
  const gameData = JSON.parse(gameDataJson);
  
  // Base64からUint8Arrayに変換するヘルパー関数（チャンク処理）
  function base64ToUint8Array(base64) {
    const binary = atob(base64);
    const bytes = new Uint8Array(binary.length);
    for (let i = 0; i < binary.length; i++) {
      bytes[i] = binary.charCodeAt(i);
    }
    return bytes;
  }
  
  const files = gameData.files.map(entry => ({
    path: entry.path,
    data: base64ToUint8Array(entry.data)
  }));
  
  // グローバル変数に保存（preRunからアクセスするため）
  window.EASYRPG_GAME_FILES = files;
  
  // グローバルなModuleオブジェクトでpreRunを設定
  window.Module = {
    preRun: [function() {
      const Module = this;
      const files = window.EASYRPG_GAME_FILES;
      
      if (!files || files.length === 0) {
        console.error("No files found in window.EASYRPG_GAME_FILES");
        return;
      }
      
      console.log("===== preRun EXECUTING =====");
      console.log("Loading", files.length, "files from window.EASYRPG_GAME_FILES");
      
      // /gamesをアンマウント
      if (Module.FS && Module.FS.analyzePath('/games').exists) {
        try {
          Module.FS.unmount('/games');
          console.log("Unmounted /games");
        } catch (e) {
          console.error("Failed to unmount /games:", e);
        }
      }
      
      // ゲームディレクトリを作成
      try {
        Module.FS.mkdir('/game');
        console.log("Created /game");
      } catch (e) {
        console.warn("Failed to create /game:", e);
      }
      
      // ファイルを展開
      let count = 0;
      for (const entry of files) {
        const filePath = '/game/' + entry.path;
        const pathParts = entry.path.split('/');
        
        if (pathParts.length > 1) {
          let currentPath = '/game';
          for (let i = 0; i < pathParts.length - 1; i++) {
            currentPath += '/' + pathParts[i];
            try {
              Module.FS.mkdir(currentPath);
            } catch (e) {}
          }
        }
        
        try {
          Module.FS.writeFile(filePath, entry.data);
          count++;
        } catch (e) {
          console.error("Failed to write", filePath, ":", e);
        }
      }
      
      console.log("✓ Loaded", count, "files in preRun");
      console.log("✓ Game directory:", Module.FS.readdir('/game').slice(0, 10));
      console.log("===== preRun COMPLETED =====");
      
      // クリーンアップ
      delete window.EASYRPG_GAME_FILES;
    }],
    game: '/game'
  };
  
  console.log("window.Module configured:", window.Module);
  
  // sessionStorageをクリア
  sessionStorage.removeItem('easyrpg_game_data');
}
</script>

<!-- window.Moduleが定義された後にindex.jsを読み込む -->
<script type="text/javascript" src="index.js"></script>

<script>
// ==========================================
// 1. ZIPファイルの解析とゲーム起動ロジック
// ==========================================
const fileInput = document.getElementById('game-file-input');
const startupDialog = document.getElementById('startup-dialog');
const statusDiv = document.getElementById('status');

// sessionStorageからゲームをロードした場合の自動起動
if (gameDataJson && typeof createEasyRpgPlayer !== 'undefined') {
  console.log("Auto-starting EasyRPG Player with loaded game data...");
  statusDiv.innerText = "ゲームを起動しています...";
  
  // データをコピーしてから削除
  const savedGameData = gameDataJson;
  sessionStorage.removeItem('easyrpg_game_data');
  
  // 通常起動（preRunは使用されない）
  createEasyRpgPlayer({}).then(async function(Module) {
    console.log("EasyRPG Player module loaded, loading custom game...");
    
    const gameData = JSON.parse(savedGameData);
    
    // Base64からUint8Arrayに変換
    function base64ToUint8Array(base64) {
      const binary = atob(base64);
      const bytes = new Uint8Array(binary.length);
      for (let i = 0; i < binary.length; i++) {
        bytes[i] = binary.charCodeAt(i);
      }
      return bytes;
    }
    
    const files = gameData.files.map(entry => ({
      path: entry.path,
      data: base64ToUint8Array(entry.data)
    }));
    
    console.log("Converting", files.length, "files...");
    
    // /gamesをアンマウント
    if (Module.FS.analyzePath('/games').exists) {
      try {
        Module.FS.unmount('/games');
        console.log("Unmounted /games");
      } catch (e) {
        console.warn("Failed to unmount:", e);
      }
    }
    
    // /gameディレクトリを作成
    try {
      Module.FS.mkdir('/game');
      console.log("Created /game");
    } catch (e) {
      console.warn("/game exists");
    }
    
    // ファイルを書き込み
    let count = 0;
    for (const entry of files) {
      const filePath = '/game/' + entry.path;
      const pathParts = entry.path.split('/');
      
      if (pathParts.length > 1) {
        let currentPath = '/game';
        for (let i = 0; i < pathParts.length - 1; i++) {
          currentPath += '/' + pathParts[i];
          try {
            Module.FS.mkdir(currentPath);
          } catch (e) {}
        }
      }
      
      try {
        Module.FS.writeFile(filePath, entry.data);
        count++;
      } catch (e) {
        console.error("Failed to write", filePath, ":", e);
      }
    }
    
    console.log("✓ Wrote", count, "files to /game");
    console.log("✓ Files:", Module.FS.readdir('/game').slice(0, 10));
    
    // index.jsonを確認
    if (Module.FS.analyzePath('/game/index.json').exists) {
      console.log("✓ index.json exists");
      
      // EasyRPG APIを初期化
      Module.initApi();
      
      // canvasにフォーカス
      canvas.focus();
      statusDiv.innerText = "";
      
      easyrpgPlayer = Module;
      
      console.log("✓ Game loaded successfully! Click on the screen to start.");
      console.log("Note: The default game may still show. This is a limitation of the current EasyRPG build.");
    } else {
      console.error("✗ index.json not found!");
    }
  }).catch(function(err) {
    console.error("Failed to start EasyRPG:", err);
    statusDiv.innerText = "エラー: ゲームの起動に失敗しました";
    startupDialog.style.display = 'flex';
  });
}

fileInput.addEventListener('change', async (event) => {
  const file = event.target.files[0];
  if (!file) return;

  // createEasyRpgPlayer が読み込まれているか確認
  if (typeof createEasyRpgPlayer === 'undefined') {
    statusDiv.innerText = "エラー: EasyRPG Player のスクリプトが読み込まれていません";
    console.error("index.js が正しく読み込まれていません");
    return;
  }

  startupDialog.style.display = 'none';
  
  try {
    statusDiv.innerText = "ZIPを解析し、インデックスを生成しています...";
    
    // JSZipで読み込み。まずUTF-8で試し、文字化けがあればShift-JISで再試行
    let zip;
    try {
      // デフォルトのUTF-8で読み込み
      zip = await JSZip.loadAsync(file);
      
      // UTF-8でのファイル名を確認
      const firstFile = Object.keys(zip.files)[0];
      if (firstFile && /[\x00-\x1F\x7F-\x9F]/.test(firstFile)) {
        // 制御文字が含まれている場合はShift-JISで再読み込み
        throw new Error("Non-UTF8 encoding detected");
      }
    } catch (err) {
      console.warn("UTF-8での読み込みに失敗。CP932(Shift-JIS)で再試行します。", err);
      // encoding-japaneseの代わりに、ブラウザのTextDecoderを利用
      zip = await JSZip.loadAsync(file, {
        decodeFileName: function (bytes) {
          try {
            // CP932/Shift-JISでデコード（Windowsの日本語環境）
            return new TextDecoder('shift-jis').decode(new Uint8Array(bytes));
          } catch (e) {
            // フォールバック: windows-1252やlatin1を試す
            try {
              return new TextDecoder('windows-1252').decode(new Uint8Array(bytes));
            } catch (e2) {
              // 最終フォールバック
              return new TextDecoder('utf-8', {fatal: false}).decode(new Uint8Array(bytes));
            }
          }
        }
      });
    }
    
    // ディレクトリ階層の解析 (フォルダごと圧縮されているか判定)
    const paths = Object.keys(zip.files);
    
    if (paths.length === 0) {
      throw new Error("ZIPファイルが空です");
    }
    
    let rootPrefix = "";
    const topLevelItems = new Set();
    let hasFileInRoot = false;

    for (const p of paths) {
      const firstSlash = p.indexOf('/');
      if (firstSlash === -1) {
        hasFileInRoot = true; // ルート直下にファイルが存在する
      } else {
        topLevelItems.add(p.substring(0, firstSlash));
      }
    }

    // ルートにファイルが一切なく、トップレベルのフォルダが1つだけなら、それを削除対象とする
    if (!hasFileInRoot && topLevelItems.size === 1) {
      rootPrefix = [...topLevelItems][0] + "/";
    }

    const newZip = new JSZip();
    const cacheTree = {};

    // 新しいZIPを作りながら、gencacheと同等の階層ツリーを構築
    for (const relativePath of paths) {
      const originalZipObj = zip.files[relativePath];
      
      // フォルダ自体、または空のエントリはスキップ
      if (!originalZipObj || originalZipObj.dir) continue;

      // 不要な親フォルダを取り除く (例: GameFolder/RPG_RT.ldb -> RPG_RT.ldb)
      const cleanPath = relativePath.startsWith(rootPrefix) 
        ? relativePath.substring(rootPrefix.length) 
        : relativePath;

      if (!cleanPath || cleanPath.toLowerCase() === 'index.json') continue;

      // 新しいZIPにデータを移動
      newZip.file(cleanPath, originalZipObj.async('arraybuffer'));

      // キャッシュツリーの構築
      const parts = cleanPath.split('/');
      let current = cacheTree;

      for (let i = 0; i < parts.length; i++) {
        const originalName = parts[i];
        const isFile = (i === parts.length - 1);
        
        // NFKC正規化と小文字化
        let lowerName = originalName.toLowerCase().normalize("NFKC");

        if (isFile) {
          let key = lowerName;
          const keepExt = (parts.length === 1) || lowerName.endsWith('.ini') || lowerName.endsWith('.po');
          const dotPos = lowerName.lastIndexOf('.');
          const stripped = dotPos === -1 ? lowerName : lowerName.substring(0, dotPos);

          if (keepExt) {
            if (stripped === 'exfont') key = 'exfont';
          } else {
            key = stripped;
          }
          current[key] = originalName;
        } else {
          // ディレクトリの場合
          if (!current[lowerName]) {
            current[lowerName] = { "_dirname": originalName };
          }
          current = current[lowerName];
        }
      }
    }

    // 生成した index.json を新しいZIPに追加
    const indexJsonStr = JSON.stringify({
      metadata: { version: 2, date: new Date().toISOString().split('T')[0] },
      cache: cacheTree
    });
    newZip.file("index.json", indexJsonStr);
    
    // デバッグ: 生成されたindex.jsonの内容を確認
    console.log("Generated index.json:", indexJsonStr);
    console.log("Cache tree:", cacheTree);
    
    // index.jsonが追加されたか確認
    const zipFilesList = Object.keys(newZip.files);
    console.log("ZIP files count:", zipFilesList.length);
    console.log("index.json in ZIP:", newZip.files["index.json"] ? "YES" : "NO");
    console.log("First 10 files:", zipFilesList.slice(0, 10));

    statusDiv.innerText = "ゲームデータを準備しています...";

    // 階層と文字化けを直した新しいZIPをUint8Arrayとして生成
    const modifiedZipData = await newZip.generateAsync({ 
      type: "uint8array", 
      compression: "STORE" 
    });
    
    // ZIPファイルの内容を事前に展開
    const reloadedZip = await JSZip.loadAsync(modifiedZipData);
    const fileEntries = [];
    
    for (const filename of Object.keys(reloadedZip.files)) {
      const zipEntry = reloadedZip.files[filename];
      if (!zipEntry.dir) {
        const fileData = await zipEntry.async('uint8array');
        fileEntries.push({ path: filename, data: fileData });
      }
    }
    
    console.log("Prepared", fileEntries.length, "files for extraction");

    statusDiv.innerText = "EasyRPG Player を起動しています...";

    // プレイヤーの起動（起動後にファイルをセットアップ）
    createEasyRpgPlayer({}).then(async function(Module) {
      console.log("EasyRPG Player module loaded, setting up game files...");
      
      // デフォルトのゲームパッケージをクリア
      if (Module.FS.analyzePath('/games').exists) {
        console.log("Unmounting /games");
        try {
          Module.FS.unmount('/games');
        } catch (e) {
          console.warn("Failed to unmount /games:", e);
        }
      }
      
      // ゲームディレクトリを作成
      try {
        Module.FS.mkdir('/game');
        console.log("Created /game directory");
      } catch (e) {
        console.log("/game already exists");
      }
      
      // ファイルを展開
      let successCount = 0;
      for (const entry of fileEntries) {
        const filePath = '/game/' + entry.path;
        
        // 親ディレクトリが存在しない場合は作成
        const pathParts = entry.path.split('/');
        if (pathParts.length > 1) {
          let currentPath = '/game';
          for (let i = 0; i < pathParts.length - 1; i++) {
            currentPath += '/' + pathParts[i];
            try {
              Module.FS.mkdir(currentPath);
            } catch (e) {
              // 既に存在する場合は無視
            }
          }
        }
        
        try {
          Module.FS.writeFile(filePath, entry.data);
          successCount++;
        } catch (e) {
          console.error("Failed to write", filePath, ":", e);
        }
      }
      
      console.log("Successfully wrote", successCount, "files to /game");
      console.log("Game directory contents (first 10):", Module.FS.readdir('/game').slice(0, 10));
      
      // index.jsonが存在するか確認
      const indexJsonPath = '/game/index.json';
      if (Module.FS.analyzePath(indexJsonPath).exists) {
        const content = Module.FS.readFile(indexJsonPath, { encoding: 'utf8' });
        console.log("✓ index.json found! Length:", content.length, "bytes");
        
        // sessionStorageにデータを保存（Base64エンコード）
        console.log("Saving game data to sessionStorage...");
        
        // Uint8ArrayをBase64に変換するヘルパー関数（チャンク処理）
        function uint8ArrayToBase64(bytes) {
          let binary = '';
          const chunkSize = 8192;
          for (let i = 0; i < bytes.length; i += chunkSize) {
            const chunk = bytes.subarray(i, i + chunkSize);
            binary += String.fromCharCode.apply(null, chunk);
          }
          return btoa(binary);
        }
        
        const gameData = {
          files: fileEntries.map(entry => ({
            path: entry.path,
            data: uint8ArrayToBase64(entry.data)
          }))
        };
        
        try {
          sessionStorage.setItem('easyrpg_game_data', JSON.stringify(gameData));
          console.log("Game data saved, reloading page...");
          window.location.reload();
        } catch (e) {
          console.error("Failed to save to sessionStorage:", e);
          statusDiv.innerText = "エラー: ゲームデータが大きすぎます";
        }
      } else {
        console.error("✗ index.json NOT found!");
        statusDiv.innerText = "エラー: index.jsonが見つかりません";
      }
    });

  } catch (err) {
    console.error("ZIPファイル処理エラー:", err);
    statusDiv.innerText = `エラー: ${err.message || 'ZIPファイルの解析に失敗しました'}`;
    startupDialog.style.display = 'flex'; // エラー時はダイアログを再表示
  }
});


// ==========================================
// 2. UI・コントロール系処理
// ==========================================

canvas.addEventListener('mouseenter', () => canvas.focus());
canvas.addEventListener('click', () => canvas.focus());

// フルスクリーンボタン
document.querySelector('#controls-fullscreen').addEventListener('click', () => {
  const viewport = document.getElementById('viewport');
  if (viewport.requestFullscreen) {
    viewport.requestFullscreen();
  }
});

// キーボードイベントのシミュレーション
function simulateKeyboardEvent(eventType, key) {
  const event = new Event(eventType, { bubbles: true });
  event.code = key;
  canvas.dispatchEvent(event);
}

function simulateKeyboardInput(key) {
  simulateKeyboardEvent('keydown', key);
  window.setTimeout(() => {
    simulateKeyboardEvent('keyup', key);
  }, 100);
}

// タッチ操作のバインド
function bindKey(node, key) {
  keys.set(node.id, key);

  node.addEventListener('touchstart', event => {
    event.preventDefault();
    simulateKeyboardEvent('keydown', key);
    keysDown.set(event.target.id, node.id);
    node.classList.add('active');
  });

  node.addEventListener('touchend', event => {
    event.preventDefault();
    const pressedKey = keysDown.get(event.target.id);
    if (pressedKey && keys.has(pressedKey)) {
      const key = keys.get(pressedKey);
      simulateKeyboardEvent('keyup', key);
    }
    keysDown.delete(event.target.id);
    node.classList.remove('active');

    if (lastTouchedId) {
      document.getElementById(lastTouchedId).classList.remove('active');
    }
  });

  node.addEventListener('touchmove', event => {
    const { target, clientX, clientY } = event.changedTouches[0];
    const origTargetId = keysDown.get(target.id);
    const nextTargetId = document.elementFromPoint(clientX, clientY).id;
    if (origTargetId === nextTargetId) return;

    if (origTargetId) {
      const key = keys.get(origTargetId);
      simulateKeyboardEvent('keyup', key);
      keysDown.delete(target.id);
      document.getElementById(origTargetId).classList.remove('active');
    }

    if (keys.has(nextTargetId)) {
      const key = keys.get(nextTargetId);
      simulateKeyboardEvent('keydown', key);
      keysDown.set(target.id, nextTargetId);
      lastTouchedId = nextTargetId;
      document.getElementById(nextTargetId).classList.add('active');
    }
  })
}

// ゲームパッド処理
let gamepads = {};
const haveEvents = 'ongamepadconnected' in window;

function addGamepad(gamepad) {
  if (gamepad == undefined) return;
  gamepads[gamepad.index] = gamepad;
  updateTouchControlsVisibility();
}

function removeGamepad(gamepad) {
  if (gamepad == undefined) return;
  delete gamepads[gamepad.index];
  updateTouchControlsVisibility();
}

function getGamepads() {
  return navigator.getGamepads ? navigator.getGamepads() : (navigator.webkitGetGamepads ? navigator.webkitGetGamepads() : []);
}

function scanGamePads() {
  var pads = getGamepads();
  for (var i = 0; i < pads.length; i++) {
    if (pads[i]) {
      if (pads[i].index in gamepads) {
        gamepads[pads[i].index] = pads[i];
      } else {
        addGamepad(pads[i]);
      }
    }
  }
}

if (!haveEvents) {
  setInterval(scanGamePads, 500);
}

window.addEventListener('gamepadconnected', function(e) { addGamepad(e.gamepad); });
window.addEventListener('gamepaddisconnected', function(e) { removeGamepad(e.gamepad); });

// タッチコントロールの表示・非表示切り替え
function updateTouchControlsVisibility() {
  if (hasTouchscreen && Object.keys(gamepads).length === 0) {
    for (const elem of document.querySelectorAll('#dpad, #apad')) elem.style.display = '';
  } else {
    for (const elem of document.querySelectorAll('#dpad, #apad')) elem.style.display = 'none';
  }
}

if (hasTouchscreen) {
  for (const button of document.querySelectorAll('[data-key]')) {
    bindKey(button, button.dataset.key);
  }
} else {
  // ネイティブのスクロール防止など
  window.addEventListener('keydown', event => {
    if (preventNativeKeys.includes(event.key)) {
      event.preventDefault();
    }
  });
  canvas.addEventListener('contextmenu', event => event.preventDefault());
}

updateTouchControlsVisibility();
</script>

</body>
</html>
